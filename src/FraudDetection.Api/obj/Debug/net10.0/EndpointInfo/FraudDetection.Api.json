{
  "openapi": "3.1.1",
  "info": {
    "title": "API.Fraud.Detection",
    "description": "API that detects fraud in card transactions using vector search for each incoming transaction.",
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://localhost:5000"
    },
    {
      "url": "http://localhost:5001"
    }
  ],
  "paths": {
    "/api/fraud/ready": {
      "get": {
        "tags": [
          "Fraud"
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/fraud/score": {
      "post": {
        "tags": [
          "Fraud"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FraudScoreRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FraudScoreResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CustomerDto": {
        "type": "object",
        "properties": {
          "avg_amount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "tx_count_24h": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "known_merchants": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "FraudScoreRequest": {
        "required": [
          "transaction",
          "customer",
          "merchant",
          "terminal"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "transaction": {
            "$ref": "#/components/schemas/TransactionDto"
          },
          "customer": {
            "$ref": "#/components/schemas/CustomerDto"
          },
          "merchant": {
            "$ref": "#/components/schemas/MerchantDto"
          },
          "terminal": {
            "$ref": "#/components/schemas/TerminalDto"
          },
          "last_transaction": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/LastTransactionDto"
              }
            ]
          }
        }
      },
      "FraudScoreResponse": {
        "required": [
          "approved",
          "score"
        ],
        "type": "object",
        "properties": {
          "approved": {
            "type": "boolean"
          },
          "score": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "LastTransactionDto": {
        "type": "object",
        "properties": {
          "timeStamp": {
            "type": "string",
            "format": "date-time"
          },
          "km_from_current": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "MerchantDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "mcc": {
            "type": "string"
          },
          "avg_amount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "TerminalDto": {
        "type": "object",
        "properties": {
          "is_online": {
            "type": "boolean"
          },
          "card_present": {
            "type": "boolean"
          },
          "km_from_home": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "TransactionDto": {
        "type": "object",
        "properties": {
          "amount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "installments": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "requested_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Fraud"
    }
  ]
}